def main() -> int:
    args = parse_args()
    config = BacktestConfig(
        network=args.network,
        token_address=args.token_address,
        quote_token_address=args.quote_token_address,
        timeframe=args.timeframe,
        aggregate=args.aggregate,
        bars=args.bars,
        rebalance_every=args.rebalance_every,
        sd_window=args.sd_window,
        vf_window=args.vf_window,
        price_window=args.price_window,
        pmf_positive_threshold=args.pmf_positive_threshold,
        pmf_negative_threshold=-abs(args.pmf_negative_threshold),
        vf_alert_threshold=args.vf_alert_threshold,
        vf_extreme_threshold=args.vf_extreme_threshold,
        tf_threshold=args.tf_threshold,
        prv_threshold=args.prv_threshold,
        prmax_threshold=args.prmax_threshold,
        prmin_threshold=args.prmin_threshold,
        base_position_index=args.base_position_index,
        add_step=args.add_step,
        reduce_step=args.reduce_step,
        initial_capital=args.initial_capital,
        fee_bps=args.fee_bps,
        slippage_bps=args.slippage_bps,
        max_position=args.max_position,
    )

    client = GeckoTerminalClient()

    try:
        if args.input_csv:
            csv_path = Path(args.input_csv)
            ohlcv_df = pd.read_csv(csv_path)
            required_cols = {"timestamp", "open", "high", "low", "close", "volume"}
            missing_cols = required_cols - set(ohlcv_df.columns)
            if missing_cols:
                raise ValueError(f"离线数据缺少字段: {sorted(missing_cols)}")
            ohlcv_df["timestamp"] = pd.to_datetime(ohlcv_df["timestamp"], utc=True)
            ohlcv_df = ohlcv_df.sort_values("timestamp").reset_index(drop=True)
            pool_address = args.pool_address or "offline_pool"
            pool_name = f"offline_csv:{csv_path.name}"
        else:
            if args.pool_address:
                pool_address = args.pool_address
                pool_name = args.pool_address
                ohlcv_df = client.get_ohlcv(
                    network=config.network,
                    pool_address=pool_address,
                    timeframe=config.timeframe,
                    aggregate=config.aggregate,
                    limit=config.bars,
                )
            elif args.market == "forex":
                if args.forex_provider != "yahoo":
                    raise ValueError(f"暂不支持的外汇数据源: {args.forex_provider}")
                ohlcv_df = get_forex_ohlcv_yahoo(
                    symbol=args.forex_symbol,
                    timeframe=config.timeframe,
                    aggregate=config.aggregate,
                    limit=config.bars,
                )
                normalized = _normalize_forex_symbol_for_yahoo(args.forex_symbol)
                pool_address = f"forex:{normalized}"
                pool_name = f"Yahoo {normalized}"
            else:
                if not args.token_address:
                    raise ValueError("market=crypto 时必须提供 --token-address")
                top_pool = client.get_top_pool(config.network, config.token_address)
                pool_address = top_pool["attributes"]["address"]
                pool_name = top_pool["attributes"].get("name", pool_address)
                ohlcv_df = client.get_ohlcv(
                    network=config.network,
                    pool_address=pool_address,
                    timeframe=config.timeframe,
                    aggregate=config.aggregate,
                    limit=config.bars,
                )
    except Exception as exc:
        print(f"链上数据获取失败: {exc}", file=sys.stderr)
        return 1

    signal_df = compute_signal_frame(ohlcv_df, config)
    result_df, metrics = run_backtest(signal_df, config)

    prefix = Path(args.output_prefix)
    csv_path = prefix.with_suffix(".csv")
    summary_path = prefix.with_suffix(".txt")

    result_df.to_csv(csv_path, index=False)
    with summary_path.open("w", encoding="utf-8") as fh:
        fh.write(f"pool_name={pool_name}\n")
        fh.write(f"pool_address={pool_address}\n")
        for key, value in metrics.items():
            fh.write(f"{key}={value}\n")

    print(f"选中的池子: {pool_name}")
    print(f"池子地址: {pool_address}")
    print(f"结果明细: {csv_path}")
    print(f"回测摘要: {summary_path}")
    print("核心指标:")
    for key, value in metrics.items():
        print(f"  {key}: {value:.6f}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
