#!/usr/bin/env python3
"""
BSC 链上数据调仓回测脚本。

默认流程：
1. 通过 GeckoTerminal API 查找 token 在 BSC 上的主流动性池。
2. 拉取池子的历史 OHLCV 数据。
3. 基于动量 + 流动性过滤生成目标仓位。
4. 按固定频率调仓并输出回测结果。

说明：
- 这是一个可运行的骨架，适合继续替换成你的自定义调仓逻辑。
- 当前环境里如果外网不可用，脚本会报网络错误，但本地回测框架仍可直接复用。
"""

from __future__ import annotations

import argparse
import math
import sys
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, List, Optional, Tuple

import pandas as pd
import requests


GECKO_TERMINAL_BASE_URL = "https://api.geckoterminal.com/api/v2"
YAHOO_CHART_BASE_URL = "https://query1.finance.yahoo.com/v8/finance/chart"
DEFAULT_TIMEOUT = 20


@dataclass
class BacktestConfig:
    network: str
    token_address: str
    quote_token_address: Optional[str]
    timeframe: str
    aggregate: int
    bars: int
    rebalance_every: int
    sd_window: int
    vf_window: int
    price_window: int
    pmf_positive_threshold: float
    pmf_negative_threshold: float
    vf_alert_threshold: float
    vf_extreme_threshold: float
    tf_threshold: float
    prv_threshold: float
    prmax_threshold: float
    prmin_threshold: float
    base_position_index: float
    add_step: float
    reduce_step: float
    initial_capital: float
    fee_bps: float
    slippage_bps: float
    max_position: float


class GeckoTerminalClient:
    def __init__(self, timeout: int = DEFAULT_TIMEOUT) -> None:
        self.timeout = timeout
        self.session = requests.Session()
        self.session.headers.update(
            {
                "Accept": "application/json",
                "User-Agent": "chain-rebalance-backtest/1.0",
            }
        )

    def _get(self, path: str, params: Optional[Dict[str, object]] = None) -> Dict:
        url = f"{GECKO_TERMINAL_BASE_URL}{path}"
        response = self.session.get(url, params=params, timeout=self.timeout)
        response.raise_for_status()
        return response.json()

    def get_top_pool(self, network: str, token_address: str) -> Dict:
        payload = self._get(f"/networks/{network}/tokens/{token_address}/pools")
        pools = payload.get("data", [])
        if not pools:
            raise ValueError(f"未找到 token={token_address} 在 network={network} 上的池子数据。")

        def pool_score(pool: Dict) -> Tuple[float, float]:
            attrs = pool.get("attributes", {})
            reserve = _safe_float(attrs.get("reserve_in_usd"))
            volume = _safe_float(attrs.get("volume_usd", {}).get("h24"))
            return reserve, volume

        pools = sorted(pools, key=pool_score, reverse=True)
        return pools[0]

    def get_ohlcv(
        self,
        network: str,
        pool_address: str,
        timeframe: str,
        aggregate: int,
        limit: int,
    ) -> pd.DataFrame:
        remaining = limit
        before_timestamp = int(time.time())
        all_rows: List[List[float]] = []

        while remaining > 0:
            batch_limit = min(remaining, 1000)
            payload = self._get(
                f"/networks/{network}/pools/{pool_address}/ohlcv/{timeframe}",
                params={
                    "aggregate": aggregate,
                    "limit": batch_limit,
                    "before_timestamp": before_timestamp,
                },
            )

            ohlcv_list = (
                payload.get("data", {})
                .get("attributes", {})
                .get("ohlcv_list", [])
            )
            if not ohlcv_list:
                break

            all_rows.extend(ohlcv_list)
            oldest_timestamp = int(ohlcv_list[-1][0])
            before_timestamp = oldest_timestamp - 1
            remaining -= len(ohlcv_list)

            if len(ohlcv_list) < batch_limit:
                break

        if not all_rows:
            raise ValueError("未获取到 OHLCV 历史数据。")

        df = pd.DataFrame(
            all_rows,
            columns=["timestamp", "open", "high", "low", "close", "volume"],
        )
        df["timestamp"] = pd.to_datetime(df["timestamp"], unit="s", utc=True)
        df = df.sort_values("timestamp").drop_duplicates("timestamp").reset_index(drop=True)
        return df


def _normalize_forex_symbol_for_yahoo(symbol: str) -> str:
    raw = (symbol or "").strip().upper().replace("-", "").replace("_", "")
    if not raw:
        raise ValueError("外汇 symbol 不能为空，例如 EURUSD 或 EURUSD=X")
    if raw.endswith("=X"):
        return raw
    if "/" in raw:
        raw = raw.replace("/", "")
    return f"{raw}=X"


def _resolve_yahoo_interval(
    timeframe: str,
    aggregate: int,
) -> Tuple[str, Optional[str], str]:
    """
    返回: (yahoo_interval, optional_resample_rule, yahoo_range)
    """
    if aggregate <= 0:
        raise ValueError("aggregate 必须大于 0")

    if timeframe == "minute":
        supported = {1, 2, 5, 15, 30, 60, 90}
        if aggregate in supported:
            interval = f"{aggregate}m"
            return interval, None, ("7d" if interval == "1m" else "60d")
        # 不在 Yahoo 原生分钟粒度内时，用 1m 拉取后本地重采样
        return "1m", f"{aggregate}min", "7d"

    if timeframe == "hour":
        if aggregate == 1:
            return "60m", None, "730d"
        return "60m", f"{aggregate}h", "730d"

    if timeframe == "day":
        if aggregate == 1:
            return "1d", None, "max"
        return "1d", f"{aggregate}D", "max"

    raise ValueError(f"不支持的 timeframe: {timeframe}")


def _resample_ohlcv(df: pd.DataFrame, rule: str) -> pd.DataFrame:
    if rule is None:
        return df
    tmp = df.copy().set_index("timestamp")
    out = (
        tmp.resample(rule)
        .agg(
            {
                "open": "first",
                "high": "max",
                "low": "min",
                "close": "last",
                "volume": "sum",
            }
        )
        .dropna(subset=["open", "high", "low", "close"])
        .reset_index()
    )
    return out


def get_forex_ohlcv_yahoo(
    symbol: str,
    timeframe: str,
    aggregate: int,
    limit: int,
    timeout: int = DEFAULT_TIMEOUT,
) -> pd.DataFrame:
    yahoo_symbol = _normalize_forex_symbol_for_yahoo(symbol)
    interval, resample_rule, yahoo_range = _resolve_yahoo_interval(timeframe, aggregate)

    url = f"{YAHOO_CHART_BASE_URL}/{yahoo_symbol}"
    range_candidates = [yahoo_range]
    # Yahoo 的风控在长区间+高频时更容易 429，降级到短窗口兜底
    if timeframe == "minute":
        range_candidates.extend(["7d", "1mo"])
    elif timeframe == "hour":
        range_candidates.extend(["6mo", "1y"])
    range_candidates = list(dict.fromkeys(range_candidates))

    session = requests.Session()
    session.headers.update(
        {
            "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)",
            "Accept": "application/json",
            "Accept-Language": "en-US,en;q=0.9",
        }
    )

    payload = None
    last_error = None
    for rng in range_candidates:
        try:
            response = session.get(
                url,
                params={
                    "range": rng,
                    "interval": interval,
                    "events": "div,splits",
                    "includePrePost": "false",
                },
                timeout=timeout,
            )
            if response.status_code == 429:
                last_error = ValueError(f"Yahoo 429 for range={rng}")
                continue
            response.raise_for_status()
            payload = response.json()
            break
        except Exception as exc:  # noqa: BLE001
            last_error = exc

    if payload is None:
        raise ValueError(f"Yahoo 行情拉取失败: {last_error}")

    result_list = payload.get("chart", {}).get("result", [])
    if not result_list:
        raise ValueError(f"Yahoo 未返回行情数据: {yahoo_symbol}")
    result = result_list[0]

    timestamps = result.get("timestamp", []) or []
    quote = (result.get("indicators", {}).get("quote", []) or [{}])[0]
    opens = quote.get("open", []) or []
    highs = quote.get("high", []) or []
    lows = quote.get("low", []) or []
    closes = quote.get("close", []) or []
    volumes = quote.get("volume", []) or []

    n = min(len(timestamps), len(opens), len(highs), len(lows), len(closes), len(volumes))
    if n == 0:
        raise ValueError(f"Yahoo 返回为空序列: {yahoo_symbol}")

    rows = []
    for i in range(n):
        o, h, l, c = opens[i], highs[i], lows[i], closes[i]
        if o is None or h is None or l is None or c is None:
            continue
        rows.append(
            {
                "timestamp": pd.to_datetime(int(timestamps[i]), unit="s", utc=True),
                "open": float(o),
                "high": float(h),
                "low": float(l),
                "close": float(c),
                # 外汇成交量常为tick volume，保留为数值列即可
                "volume": float(volumes[i] if volumes[i] is not None else 0.0),
            }
        )

    if not rows:
        raise ValueError(f"Yahoo 数据均为空K线: {yahoo_symbol}")

    df = pd.DataFrame(rows).sort_values("timestamp").drop_duplicates("timestamp")
    df = _resample_ohlcv(df, resample_rule)
    if df.empty:
        raise ValueError("重采样后无有效 OHLCV 数据")

    return df.tail(limit).reset_index(drop=True)


def _safe_float(value: object) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        return 0.0


def compute_signal_frame(df: pd.DataFrame, config: BacktestConfig) -> pd.DataFrame:
    frame = df.copy()
    frame["ret_1"] = frame["close"].pct_change().fillna(0.0)
    frame["bar_return"] = (frame["close"] - frame["open"]) / frame["open"].replace(0, float("nan"))
    frame["spmf1"] = frame["close"].pct_change(5)
    frame["spmf2"] = frame["close"].pct_change(10)
    frame["spmf3"] = frame["close"].pct_change(1)
    frame["spmf4"] = frame["close"].pct_change(5)
    frame["pmf1"] = 0.5 * frame["spmf1"].fillna(0.0) + 0.5 * frame["spmf2"].fillna(0.0)
    frame["pmf2"] = 0.5 * frame["spmf3"].fillna(0.0) + 0.5 * frame["spmf4"].fillna(0.0)
    frame["vol_ma"] = frame["volume"].rolling(config.vf_window).mean()
    frame["vf"] = frame["volume"] / frame["vol_ma"]
    frame["tf"] = (frame["close"] - frame["low"]) / (frame["high"] - frame["low"]).replace(0, float("nan"))
    frame["prv"] = frame["volume"] * frame["bar_return"].abs()
    frame["prv_ma"] = frame["prv"].rolling(config.vf_window).mean()
    frame["prv_ratio"] = frame["prv"] / frame["prv_ma"]
    frame["prmax"] = (frame["high"] - frame["open"]) / frame["open"].replace(0, float("nan"))
    frame["prmin"] = (frame["low"] - frame["open"]) / frame["open"].replace(0, float("nan"))
    frame["tf1"] = frame["tf"]
    frame["tf2"] = frame["tf"].rolling(2).mean()
    frame["vf1"] = frame["vf"]
    frame["vf2"] = frame["vf"].rolling(2).mean()
    frame["pmf"] = frame["pmf1"]
    frame["sd"] = frame["pmf1"].gt(0).rolling(config.sd_window).mean()
    frame["rolling_low_prev"] = frame["low"].shift(1).rolling(config.price_window).min()
    frame["rolling_high_prev"] = frame["high"].shift(1).rolling(config.price_window).max()
    frame["is_new_low"] = frame["low"] < frame["rolling_low_prev"]
    frame["is_new_high"] = frame["high"] > frame["rolling_high_prev"]
    frame["bullish"] = frame["close"] > frame["open"]
    frame["bearish"] = frame["close"] < frame["open"]
    frame["vf_decline_3"] = (
        (frame["vf"] < frame["vf"].shift(1))
        & (frame["vf"].shift(1) < frame["vf"].shift(2))
        & (frame["vf"].shift(2) < frame["vf"].shift(3))
    )
    frame["high_up_3"] = (
        (frame["high"] > frame["high"].shift(1))
        & (frame["high"].shift(1) > frame["high"].shift(2))
        & (frame["high"].shift(2) > frame["high"].shift(3))
    )
    frame["low_down_3"] = (
        (frame["low"] < frame["low"].shift(1))
        & (frame["low"].shift(1) < frame["low"].shift(2))
        & (frame["low"].shift(2) < frame["low"].shift(3))
    )
    frame["vol_down_3"] = (
        (frame["volume"] < frame["volume"].shift(1))
        & (frame["volume"].shift(1) < frame["volume"].shift(2))
        & (frame["volume"].shift(2) < frame["volume"].shift(3))
    )
    frame["trend_regime"] = frame["sd"].apply(classify_trend_regime)
    frame["pmf1_state"] = frame["pmf1"].apply(
        lambda x: classify_pmf_state(
            x,
            positive_threshold=config.pmf_positive_threshold,
            negative_threshold=config.pmf_negative_threshold,
        )
    )
    frame["pmf2_state"] = frame["pmf2"].apply(
        lambda x: classify_pmf_state(
            x,
            positive_threshold=config.pmf_positive_threshold,
            negative_threshold=config.pmf_negative_threshold,
        )
    )
    frame["volume_state"] = frame["vf"].apply(
        lambda x: classify_vf_state(
            x,
            alert_threshold=config.vf_alert_threshold,
            extreme_threshold=config.vf_extreme_threshold,
        )
    )
    frame["warning_price"] = pd.NA
    frame["push_signal"] = False
    frame["action_reason"] = ""
    frame["position_index"] = float(config.base_position_index)
    frame["score"] = build_rebalance_score(frame)
    frame["target_weight"] = build_position_path(frame, config)
    return frame


def build_rebalance_score(frame: pd.DataFrame) -> pd.Series:
    """
    这里的评分不再是简单动量，而是对你提出的 PMF / SD / VF 逻辑做数值化表达。

    含义：
    - `pmf1` 对应加仓通道，由 5 期和 10 期价格动能组成。
    - `pmf2` 对应减仓通道，由 1 期和 5 期价格动能组成。
    - `sd` 反映最近 N 个窗口里，加仓通道为正的窗口占比，即趋势持续性。
    - `vf` 反映当前成交量相对于近期均值是否异常放大或衰减。
    """
    pmf_component = frame["pmf1"].fillna(0.0) * 0.35 + frame["pmf2"].fillna(0.0) * 0.25
    sd_component = (frame["sd"].fillna(0.5) - 0.5) * 1.2
    vf_component = (frame["vf"].fillna(1.0) - 1.0) * 0.2
    return pmf_component + sd_component + vf_component


def classify_trend_regime(sd: float) -> str:
    if pd.isna(sd):
        return "neutral"
    if sd > 0.5:
        return "uptrend"
    if sd < 0.5:
        return "downtrend"
    return "neutral"


def classify_pmf_state(pmf: float, positive_threshold: float, negative_threshold: float) -> str:
    if pd.isna(pmf):
        return "neutral"
    if pmf >= positive_threshold:
        return "positive"
    if pmf <= negative_threshold:
        return "negative"
    return "neutral"


def classify_vf_state(vf: float, alert_threshold: float, extreme_threshold: float) -> str:
    if pd.isna(vf):
        return "normal"
    if vf >= extreme_threshold:
        return "extreme"
    if vf >= alert_threshold:
        return "alert"
    if vf < 0.8:
        return "weak"
    return "normal"


def build_position_path(frame: pd.DataFrame, config: BacktestConfig) -> pd.Series:
    """
    按你最新流程图逻辑逐根生成目标仓位（序列确认版）：
    1) SD > 50% + PMF1 达标：若出现“连续抬高后量能衰减”或“创新高阳线且VF2>2”，立即减仓。
    2) SD <= 50% + PMF2 达标：先满足“连续创新低+创新低阴线”，再走两根阳线确认，
       且第二根需要“最高价突破+放量”后才加仓。
    3) 加仓后若再次跌破前一根最低价，立即减仓。
    """
    target_weights: List[float] = []
    position_index = float(config.base_position_index)
    pending_low_setup: Optional[Dict[str, object]] = None
    post_add_low_break_watch = False

    for idx, row in frame.iterrows():
        sd = float(row["sd"]) if pd.notna(row["sd"]) else 0.5
        pmf1 = float(row["pmf1"]) if pd.notna(row["pmf1"]) else 0.0
        pmf2 = float(row["pmf2"]) if pd.notna(row["pmf2"]) else 0.0
        vf2 = float(row["vf2"]) if pd.notna(row["vf2"]) else 1.0
        close_price = float(row["close"])
        low_price = float(row["low"])
        high_price = float(row["high"])
        prev_low = float(frame.iloc[idx - 1]["low"]) if idx > 0 else low_price
        prev_high = float(frame.iloc[idx - 1]["high"]) if idx > 0 else high_price
        prev_volume = float(frame.iloc[idx - 1]["volume"]) if idx > 0 else float(row["volume"])
        bearish = bool(row["bearish"])
        bullish = bool(row["bullish"])
        is_new_low = bool(row["is_new_low"]) if pd.notna(row["is_new_low"]) else False
        is_new_high = bool(row["is_new_high"]) if pd.notna(row["is_new_high"]) else False
        high_up_3 = bool(row["high_up_3"]) if pd.notna(row["high_up_3"]) else False
        low_down_3 = bool(row["low_down_3"]) if pd.notna(row["low_down_3"]) else False
        vol_down_3 = bool(row["vol_down_3"]) if pd.notna(row["vol_down_3"]) else False
        action_reasons: List[str] = []
        push_signal = False
        
        # 左侧分支：SD>50% + PMF1 达标，满足任一条件立即减仓
        if sd > 0.5 and pmf1 >= config.pmf_positive_threshold and high_up_3:
            if vol_down_3:
                position_index = clamp_position_index(position_index - config.reduce_step)
                action_reasons.append("新逻辑: 高点连续抬升但量能连续衰减，立即减仓")
                push_signal = True
            if is_new_high and bullish and vf2 > 2.0:
                position_index = clamp_position_index(position_index - config.reduce_step)
                action_reasons.append("新逻辑: 创新高阳线且VF2>2，立即减仓")
                push_signal = True

        # 右侧分支：SD<=50% + PMF2 达标，创新低后走两步确认加仓
        if sd <= 0.5 and pmf2 <= config.pmf_negative_threshold:
            if low_down_3 and is_new_low and bearish:
                pending_low_setup = {"stage": 0, "born_idx": idx}
                action_reasons.append("新逻辑: 连续创新低且创新低阴线，启动低位反转确认")
            elif low_down_3 and is_new_low and bullish:
                pending_low_setup = {"stage": 2, "born_idx": idx}
                action_reasons.append("新逻辑: 连续创新低且创新低阳线，等待延续确认")

        if pending_low_setup is not None:
            stage = int(pending_low_setup["stage"])
            born_idx = int(pending_low_setup.get("born_idx", idx))
            if stage == 0 and bullish:
                pending_low_setup["stage"] = 1
                action_reasons.append("新逻辑: 创新低后下一根转阳，进入二次确认")
            elif stage == 1 and bullish and (high_price > prev_high) and (float(row["volume"]) > prev_volume):
                position_index = clamp_position_index(position_index + config.add_step)
                post_add_low_break_watch = True
                pending_low_setup = None
                action_reasons.append("新逻辑: 二次阳线且突破并放量，加仓")
                push_signal = True
            elif stage == 2:
                # 创新低当根为阳线：仅观察下一根是否继续阳线并突破放量
                if idx > born_idx and bullish and (high_price > prev_high) and (float(row["volume"]) > prev_volume):
                    position_index = clamp_position_index(position_index + config.add_step)
                    post_add_low_break_watch = True
                    pending_low_setup = None
                    action_reasons.append("新逻辑: 创新低阳线后延续突破并放量，加仓")
                    push_signal = True
                elif idx > born_idx:
                    pending_low_setup = None

        # 加仓后若再破前低，立即减仓
        if post_add_low_break_watch and idx > 0 and (low_price < prev_low):
            position_index = clamp_position_index(position_index - config.reduce_step)
            post_add_low_break_watch = False
            action_reasons.append("新逻辑: 加仓后最低价再破前低，立即减仓")
            push_signal = True

        frame.at[idx, "warning_price"] = pd.NA
        frame.at[idx, "push_signal"] = push_signal
        frame.at[idx, "action_reason"] = "；".join(action_reasons)
        frame.at[idx, "position_index"] = position_index
        target_weights.append(position_index / 5.0)

    return pd.Series(target_weights, index=frame.index)


def clamp_position_index(position_index: float) -> float:
    return float(min(max(1.0, position_index), 5.0))


def run_backtest(signal_df: pd.DataFrame, config: BacktestConfig) -> Tuple[pd.DataFrame, Dict[str, float]]:
    frame = signal_df.copy()
    current_weight = 0.0
    equity = config.initial_capital
    units = 0.0
    trade_count = 0
    records: List[Dict[str, float]] = []

    total_cost_rate = (config.fee_bps + config.slippage_bps) / 10000.0

    for i, row in frame.iterrows():
        price = float(row["close"])
        ret = float(row["ret_1"])

        if i == 0:
            portfolio_value = equity
        else:
            portfolio_value = units * price + equity

        should_rebalance = i % config.rebalance_every == 0
        target_weight = float(row["target_weight"]) if pd.notna(row["target_weight"]) else 0.0

        if should_rebalance:
            desired_token_value = portfolio_value * target_weight
            current_token_value = units * price
            turnover = abs(desired_token_value - current_token_value)
            trading_cost = turnover * total_cost_rate

            if turnover > 0:
                trade_count += 1

            portfolio_value_after_cost = portfolio_value - trading_cost
            desired_token_value = portfolio_value_after_cost * target_weight
            equity = portfolio_value_after_cost - desired_token_value
            units = desired_token_value / price if price > 0 else 0.0
            current_weight = target_weight
        else:
            current_weight = 0.0 if portfolio_value <= 0 else (units * price) / portfolio_value

        end_value = units * price + equity
        records.append(
            {
                "timestamp": row["timestamp"],
                "close": price,
                "ret_1": ret,
                "score": row["score"],
                "trend_regime": row.get("trend_regime", ""),
                "pmf1": row.get("pmf1", 0.0),
                "pmf2": row.get("pmf2", 0.0),
                "tf1": row.get("tf1", 0.0),
                "tf2": row.get("tf2", 0.0),
                "vf1": row.get("vf1", 0.0),
                "vf2": row.get("vf2", 0.0),
                "prv_ratio": row.get("prv_ratio", 0.0),
                "prmax": row.get("prmax", 0.0),
                "prmin": row.get("prmin", 0.0),
                "pmf1_state": row.get("pmf1_state", ""),
                "pmf2_state": row.get("pmf2_state", ""),
                "volume_state": row.get("volume_state", ""),
                "push_signal": row.get("push_signal", False),
                "action_reason": row.get("action_reason", ""),
                "position_index": row.get("position_index", 1.0),
                "target_weight": target_weight,
                "actual_weight": current_weight,
                "equity_curve": end_value,
            }
        )

    result = pd.DataFrame(records)
    result["equity_return"] = result["equity_curve"].pct_change().fillna(0.0)

    metrics = summarize_performance(result["equity_curve"], result["equity_return"], trade_count)
    return result, metrics


def summarize_performance(
    equity_curve: pd.Series,
    returns: pd.Series,
    trade_count: int,
) -> Dict[str, float]:
    total_return = equity_curve.iloc[-1] / equity_curve.iloc[0] - 1 if len(equity_curve) > 1 else 0.0
    running_max = equity_curve.cummax()
    drawdown = equity_curve / running_max - 1
    max_drawdown = drawdown.min() if len(drawdown) else 0.0

    if returns.std(ddof=0) > 0:
        sharpe = (returns.mean() / returns.std(ddof=0)) * math.sqrt(365)
    else:
        sharpe = 0.0

    return {
        "final_equity": float(equity_curve.iloc[-1]),
        "total_return": float(total_return),
        "max_drawdown": float(max_drawdown),
        "sharpe_proxy": float(sharpe),
        "trade_count": float(trade_count),
    }


